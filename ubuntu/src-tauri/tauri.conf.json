{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "myPad",
  "version": "0.1.0",
  "identifier": "com.local.mypad",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "myPad",
        "width": 960,
        "height": 640,
        "minWidth": 720,
        "minHeight": 460,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "category": "Productivity",
    "shortDescription": "A small scratchpad for quick notes",
    "longDescription": "myPad is a small local-first scratchpad app with tabs, session restore, and plain-text Markdown helpers."
  }
}
